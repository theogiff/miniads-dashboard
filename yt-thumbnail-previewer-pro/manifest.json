{
  "manifest_version": 3,
  "name": "YT Thumbnail Previewer Pro",
  "version": "0.1.0",
  "description": "Prévisualisez vos miniatures directement sur YouTube (home, search, channel, watch 'Up next').",
  "permissions": ["storage", "tabs"],
  "host_permissions": ["https://www.youtube.com/*"],
  "background": {
    "service_worker": "service_worker.js"
  },
  "content_scripts": [
    {
      "matches": ["https://www.youtube.com/*"],
      "js": ["content.js"],
      "css": ["inject.css", "overlay.css"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_title": "Visualisateur YouTube"
  },
  "commands": {
    "open-yt-popup": {
      "suggested_key": {
        "default": "Ctrl+Shift+Y"
      },
      "description": "Ouvrir YouTube en popup avec le Visualisateur"
    }
  }
}
